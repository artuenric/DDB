# IP real desta máquina no laboratório (Exemplo: 192.168.1.10)
MY_IP=192.168.1.10

# Lista de todos os IPs das máquinas que participam (incluindo esta)
ALL_NODES=192.168.1.10,192.168.1.11,192.168.1.12

# Um número único para o MySQL (ex: 1, 2 ou 3)
ID_NODO=1

# Senha do banco
DB_PASS=root

# Necessário para o X11 (normalmente :0 no Linux)
DISPLAY=:0